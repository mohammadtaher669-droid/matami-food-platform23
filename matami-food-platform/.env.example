# ══════════════════════════════════════════════════════════════════════════════
# Mat'ami Food Platform — Environment Variables
# Copy this file to .env and fill in real values before starting the server.
# NEVER commit .env to version control.
# ══════════════════════════════════════════════════════════════════════════════

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Local development (no SSL):
DATABASE_URL=postgresql://user:password@localhost:5432/matami

# Railway: set in the Variables panel — Railway injects DATABASE_URL automatically
# when you link a Postgres plugin (no SSL needed on private network).

# ── JWT Authentication ────────────────────────────────────────────────────────
# REQUIRED in production. Generate with:  openssl rand -hex 32
JWT_SECRET=change_me_to_a_secure_random_string_at_least_32_chars

# ── Admin Panel Password ──────────────────────────────────────────────────────
# Password for the /admin panel. Change before going live.
ADMIN_PASSWORD=your_secure_admin_password_here

# ── Server ────────────────────────────────────────────────────────────────────
# Railway injects PORT automatically. Set for local dev.
PORT=3001
NODE_ENV=development

# ── API Proxy (frontend dev server only) ─────────────────────────────────────
# Port the backend dev server listens on (must match PORT above)
API_PORT=3001

# ── Cloudinary (optional — cloud image hosting) ───────────────────────────────
# Without Cloudinary, images are stored as base64 in PostgreSQL (fine for small
# catalogs, but makes the database larger over time).
# Get credentials at https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
# Or use the single-URL format (takes precedence if set):
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
