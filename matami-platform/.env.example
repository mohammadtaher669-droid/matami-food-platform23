# ── Required ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/matami
JWT_SECRET=generate-with-openssl-rand-hex-32-min-32-chars
SUPER_ADMIN_EMAIL=owner@example.com
SUPER_ADMIN_PASSWORD=change-me-strong-password

# ── Optional integrations ─────────────────────────────────────────────────────
# Cloudinary media storage (image uploads stay disabled until set)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google Maps JS API key (zone editor + address picker)
GOOGLE_MAPS_API_KEY=

# Public URL of the deployment, e.g. https://matami.up.railway.app
APP_URL=
